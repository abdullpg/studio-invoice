# --- Database (SQLite / WAL, offline) ---
# File DB tersimpan di prisma/dev.db. Untuk migrasi ke DB lain,
# cukup ganti URL ini lalu jalankan: npx prisma migrate deploy
DATABASE_URL="file:./dev.db"

# --- Auth.js v5 (NextAuth) ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# --- Seed akun producer (dipakai sekali oleh `npm run db:seed`) ---
SEED_EMAIL="producer@studio.local"
SEED_PASSWORD="ganti-password-ini"
